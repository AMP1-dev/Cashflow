# Copie este arquivo para ".env" e preencha com as credenciais do seu projeto Supabase.
# Encontre esses valores em: Supabase Dashboard -> Project Settings -> API
#
# A "anon key" é pública por design (é protegida pelas políticas de RLS no
# banco, não por estar em segredo) — ainda assim, não commite o arquivo .env
# real no Git; apenas este .env.example deve ir para o repositório.

VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key-aqui
